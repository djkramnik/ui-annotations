DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ui_annotations

# Optional filtering for interactive rows before upload.
# SCREEN_TAG=service_manual
LABELS=button,textinput,dropdown

# Naming and split.
CLASSIFIER_RUN_NAME=classifier-2026-02-27-00-00-00
TRAIN_SPLIT=0.8
UPLOAD_CONCURRENCY=20

# AWS + SageMaker required values.
# Optional local AWS named profile (from ~/.aws/credentials).
# AWS_PROFILE=ui-anno-ml
AWS_REGION=us-east-1
AWS_S3_BUCKET=my-training-bucket
AWS_SAGEMAKER_ROLE_ARN=arn:aws:iam::123456789012:role/service-role/AmazonSageMaker-ExecutionRole
AWS_SAGEMAKER_IMAGE_URI=123456789012.dkr.ecr.us-east-1.amazonaws.com/classifier-prep:latest

# Optional S3 locations (defaults are derived from bucket + run name).
# AWS_SAGEMAKER_DATASET_URI=s3://my-training-bucket/classifier/classifier-2026-02-27-00-00-00
# AWS_SAGEMAKER_OUTPUT_URI=s3://my-training-bucket/classifier-models/classifier-2026-02-27-00-00-00

# SageMaker training infrastructure overrides.
AWS_SAGEMAKER_INSTANCE_TYPE=ml.g5.xlarge
AWS_SAGEMAKER_INSTANCE_COUNT=1
AWS_SAGEMAKER_VOLUME_SIZE_GB=100
AWS_SAGEMAKER_MAX_RUNTIME_SECONDS=7200

# Container hyperparameters forwarded to train.py.
MODEL_NAME=vit_base_patch16_224
EPOCHS=5
BATCH_SIZE=32
LEARNING_RATE=0.0003
WEIGHT_DECAY=0.01
IMAGE_SIZE=224
NUM_WORKERS=4
SEED=42

# Set true to skip writing dataset and only submit SageMaker job.
# SKIP_DATA_UPLOAD=true
