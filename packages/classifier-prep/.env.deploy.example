# Required for job/deploy_docker.sh
# None: this script can run with defaults plus valid AWS credentials.

# Optional values below

# Optional local AWS named profile used for AWS CLI calls.
# AWS_PROFILE=ui-anno-ml

# Optional AWS account override (otherwise resolved via sts get-caller-identity).
# AWS_ACCOUNT_ID=123456789012

# Optional ECR/deploy settings.
AWS_REGION=us-east-1
AWS_ECR_REPOSITORY=classifier-prep
AWS_SAGEMAKER_IMAGE_TAG=latest
